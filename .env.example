# BrixHub API Configuration
# Get your API key from: https://brixhub.site/api-docs

# Required: Your BrixHub API key (starts with brix_)
BRIXHUB_API_KEY=brix_your_api_key_here

# Optional: Custom User-Agent (default: brixhub-go/1.0.0)
# BRIXHUB_USER_AGENT=your-custom-user-agent

# Optional: API Base URL (default: https://brixhub.net/api/v1)
# BRIXHUB_BASE_URL=https://brixhub.net/api/v1